[Desktop Entry]
Name=Lilim AI
GenericName=AI Assistant
Comment=Your infernal AI assistant — Ctrl+Shift+L to summon
Exec=/usr/bin/lilim-desktop
Icon=/usr/share/icons/lilith/lilim.png
Terminal=false
Type=Application
Categories=Utility;Development;Science;Education;
Keywords=AI;assistant;code;interpreter;linux;lilith;
StartupWMClass=lilim-ai
StartupNotify=true
X-GNOME-Autostart-enabled=true
Actions=toggle;settings;

[Desktop Action toggle]
Name=Toggle Lilim Window
Exec=dbus-send --session --type=method_call --dest=com.lilith.lilim /window com.lilith.lilim.Toggle

[Desktop Action settings]
Name=Settings
Exec=/usr/bin/lilim-desktop --settings
