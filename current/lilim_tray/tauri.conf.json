{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v1.6.15/core/tauri-config-schema/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../ui",
    "distDir": "../ui"
  },
  "package": {
    "productName": "Lilim",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "globalShortcut": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "identifier": "com.lilith.lilim",
      "longDescription": "Lilim AI Assistant - RAG-powered AI helper for Lilith Linux",
      "resources": [],
      "shortDescription": "AI Assistant",
      "targets": "all",
      "icon": [
        "icons/icon.png"
      ]
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Lilim - AI Assistant",
        "width": 600,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": true,
        "center": true
      }
    ]
  }
}
